# Copy to `.env` or `.env.production` and adjust.

# GitHub Pages: set to your repository name with slashes, e.g. /foodpicker/
# For username.github.io root site, use /
VITE_BASE_PATH=/

# osm (default) | mock | api | yelp-proxy
# osm = OpenStreetMap via Overpass + Nominatim for ZIP geocoding
VITE_DATA_MODE=osm

# When VITE_DATA_MODE=api — your backend or serverless URL (no secrets in frontend).
VITE_RESTAURANTS_API_URL=

# Optional: header "Authorization: Bearer <token>" if your proxy expects it.
VITE_API_AUTH_HEADER=

# When VITE_DATA_MODE=yelp-proxy — your serverless Yelp facade URL (see README).
VITE_YELP_PROXY_URL=
